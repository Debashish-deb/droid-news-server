<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        ╔══════════════════════════════════════════════════════════╗
        ║  BD Info Hub — Bangladesh Flag Theme                    ║
        ║  Forest Green · Crimson Red · Edge-to-edge              ║
        ╚══════════════════════════════════════════════════════════╝
    -->

    <!-- ═══ LAUNCH / SPLASH THEME ═══════════════════════════════
         Transparent native launch surface; Flutter paints the UI. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">

        <!-- Keep the native splash surface transparent. -->
        <item name="android:windowBackground">@color/splash_background</item>

        <!-- GPU rendering from frame 1 -->
        <item name="android:hardwareAccelerated">true</item>

        <!-- True edge-to-edge -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/status_bar_transparent</item>
        <item name="android:navigationBarColor">@color/nav_bar_transparent</item>

        <!-- Dark icons for the transparent light launch surface -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- No title bar chrome -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>

        <!-- Crisp entry — no lag -->
        <item name="android:windowDisablePreview">false</item>
        <item name="android:windowActivityTransitions">true</item>

    </style>


    <!-- ═══ NORMAL / FLUTTER RUNTIME THEME ═══════════════════════ -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">

        <!-- Soft off-white scaffold after Flutter takes over -->
        <item name="android:windowBackground">@color/window_background</item>

        <item name="android:hardwareAccelerated">true</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Dark icons once Flutter's light scaffold is visible -->
        <item name="android:windowLightStatusBar">true</item>

        <!-- Smooth shared-element & page transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>

        <item name="android:windowSoftInputMode">adjustResize</item>

        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>

    </style>


    <!-- ═══ DIALOG THEME ══════════════════════════════════════════ -->
    <style name="PremiumDialog" parent="@android:style/Theme.Material.Light.Dialog">
        <item name="android:windowBackground">@color/dialog_background</item>
        <item name="android:windowElevation">24dp</item>
        <item name="android:colorAccent">@color/flag_red</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:hardwareAccelerated">true</item>
    </style>

</resources>
