<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        ╔══════════════════════════════════════════════════════════╗
        ║  BD Info Hub — Bangladesh Flag Theme                    ║
        ║  Forest Green · Crimson Red · Edge-to-edge              ║
        ╚══════════════════════════════════════════════════════════╝
    -->

    <!-- ═══ LAUNCH / SPLASH THEME ═══════════════════════════════
         Deep national-flag green fills the window instantly —
         the exact shade from the Government of Bangladesh spec.  -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">

        <!-- Official BD flag green — zero white flash on cold start -->
        <item name="android:windowBackground">@color/splash_background</item>

        <!-- GPU rendering from frame 1 -->
        <item name="android:hardwareAccelerated">true</item>

        <!-- Prevent OS auto-dark from washing out the flag green -->
        <item name="android:forceDarkAllowed">false</item>

        <!-- True edge-to-edge -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@color/status_bar_transparent</item>
        <item name="android:navigationBarColor">@color/nav_bar_transparent</item>

        <!-- White icons on the green status bar -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Render behind display notch / punch-hole -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <!-- No title bar chrome -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>

        <!-- Crisp entry — no lag -->
        <item name="android:windowDisablePreview">false</item>
        <item name="android:windowActivityTransitions">true</item>

    </style>


    <!-- ═══ NORMAL / FLUTTER RUNTIME THEME ═══════════════════════ -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">

        <!-- Soft off-white scaffold — readable after the green splash -->
        <item name="android:windowBackground">@color/window_background</item>

        <item name="android:hardwareAccelerated">true</item>

        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Dark icons once Flutter's light scaffold is visible -->
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <!-- Smooth shared-element & page transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <item name="android:windowContentTransitions">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
        <item name="android:windowAllowReturnTransitionOverlap">true</item>

        <item name="android:windowSoftInputMode">adjustResize</item>

        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:forceDarkAllowed">false</item>

    </style>


    <!-- ═══ DIALOG THEME ══════════════════════════════════════════ -->
    <style name="PremiumDialog" parent="@android:style/Theme.Material.Light.Dialog">
        <item name="android:windowBackground">@color/dialog_background</item>
        <item name="android:windowElevation">24dp</item>
        <item name="android:colorAccent">@color/flag_red</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:hardwareAccelerated">true</item>
    </style>

</resources>