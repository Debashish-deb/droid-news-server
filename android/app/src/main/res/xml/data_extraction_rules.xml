<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Flutter SharedPreferences are stored in a single XML file, so
             key-level allow-listing is not possible here. Keep cloud backup
             explicit and empty rather than accidentally backing up all prefs. -->
    </cloud-backup>
    <device-transfer>
        <!-- Same rationale as cloud-backup above. -->
    </device-transfer>
</data-extraction-rules>
