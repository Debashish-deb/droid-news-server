<?xml version="1.0" encoding="utf-8"?>
<!--
    Cloud Backup & Device Transfer rules for BD News Reader.
    SECURITY: Exclude databases, secure storage, and auth-related prefs.
    Only non-sensitive user preferences (theme, language) are backed up.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude everything by default, then whitelist safe prefs -->
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>

        <!-- Only back up non-sensitive display preferences -->
        <include domain="sharedpref" path="FlutterSharedPreferences.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- On device-to-device transfer, exclude all sensitive data -->
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="external" path="."/>
        <exclude domain="root" path="."/>

        <!-- Only transfer display preferences -->
        <include domain="sharedpref" path="FlutterSharedPreferences.xml"/>
    </device-transfer>
</data-extraction-rules>
