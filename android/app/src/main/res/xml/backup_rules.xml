<?xml version="1.0" encoding="utf-8"?>
<!--
    Legacy Backup Rules (API < 31) for BD News Reader.
    SECURITY: Exclude all sensitive data, only allow display preferences.
-->
<full-backup-content>
    <!-- Exclude everything first -->
    <exclude domain="file" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="external" path="."/>
    <exclude domain="root" path="."/>

    <!-- Only back up non-sensitive display preferences -->
    <include domain="sharedpref" path="FlutterSharedPreferences.xml"/>
</full-backup-content>
