# BD News Reader - Environment Template
# Copy this file to .env and fill in your own keys.
# DO NOT COMMIT THE .env FILE TO VERSION CONTROL.

# AI & Content
GEMINI_API_KEY=your_gemini_api_key_here
NEWSDATA_API_KEY=your_newsdata_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# Firebase Configuration
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_API_KEY_ANDROID=your_android_api_key
FIREBASE_APP_ID_ANDROID=your_android_app_id

# Auth & OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
FIREBASE_ANDROID_CLIENT_ID=your_firebase_android_client_id_here

# Backend
BACKEND_URL=https://your-production-api.com
